{{ 'velo-forge-clarity-embed.css' | asset_url | stylesheet_tag }}
<script src="{{ 'velo-forge-clarity-embed.js' | asset_url }}" defer="defer"></script>

<section class="shopify-section velo-forge-clarity-main-product" data-testid="velo-forge-clarity-main-product-section">
  {% render 'velo-forge-clarity-configurator-root', product: product, configurator_app_url: section.settings.configurator_app_url %}
</section>

{% schema %}
{
  "name": "Velo Forge configurator",
  "settings": [
    {
      "type": "text",
      "id": "configurator_app_url",
      "label": "Configurator app URL",
      "info": "External URL for the deployed configurator app. Used for API calls and locked renderer assets.",
      "default": "https://channel-studio-4.preview.emergentagent.com"
    }
  ],
  "presets": [
    {
      "name": "Velo Forge configurator"
    }
  ]
}
{% endschema %}